# GitHub Personal Access Token
# 生成地址: https://github.com/settings/tokens
# 需要 repo 和 read:user 权限
GITHUB_TOKEN=your_github_token_here

# Optional: OpenAI-compatible query expansion, e.g. OpenRouter
# Keep disabled unless you explicitly want LLM-assisted alias/query expansion.
ENABLE_LLM_QUERY_EXPANSION=false
OPENAI_API_KEY=your_openai_or_openrouter_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-120b:free
